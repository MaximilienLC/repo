# ~ Ubuntu ~ #
FROM ubuntu:24.04
# Moves Python cache file creation to a different folder
ENV PYTHONPYCACHEPREFIX=/.cache/python/
# Install system packages
RUN apt update && apt install -y \
    # For git pip install
    git \
    # Python
    python3-pip \
    python-is-python3 \
    # Java to build our fork of Hydra
    default-jre \
    # Audio libraries
    ffmpeg \
    sox \
    libavdevice-dev \
    # Required by soundfile
    libffi8 \
    # Required for uv
    curl \
    # Clean up
    && rm -rf /var/lib/apt/lists/*
# Feed `pyproject.toml` to the build context
ADD pyproject.toml /repo/pyproject.toml
# Install Python dependencies
RUN pip install uv==0.8.4 --break-system-packages \
    && uv pip install --break-system-packages --system --no-cache-dir -e /ai_repo[cpu,core,dev,docs,nb,fmri,audio,tensor,hpo,rl,dl,dl_utils,logging.misc] --extra-index-url https://download.pytorch.org/whl/cpu  --index-strategy unsafe-best-match
