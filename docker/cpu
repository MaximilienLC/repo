FROM ubuntu:24.04
# Moves Python cache file creation to a different folder
ENV PYTHONPYCACHEPREFIX=/.cache/python/
# Install system packages
RUN apt update && apt install -y \
    # For git pip install
    git \
    # Python
    python3-pip \
    python-is-python3 \
    # Java to build our fork of Hydra
    default-jre \
    # For audio libraries
    ffmpeg \
    sox \
    libavdevice-dev \
    libffi8 \
    # Clean up
    && rm -rf /var/lib/apt/lists/*
# Feed `pyproject.toml` to the build context
ADD pyproject.toml /repo/pyproject.toml
# Install Python dependencies
RUN pip install --no-cache-dir --break-system-packages torch==2.7.1 torchvision==0.22.1 torchaudio==2.7.1 --index-url https://download.pytorch.org/whl/cpu \
    && pip install --no-cache-dir --break-system-packages -e /repo[all]