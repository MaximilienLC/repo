FROM pytorch/pytorch:2.7.1-cuda12.8-cudnn9-devel
# Moves Python cache file creation to a different folder
ENV PYTHONPYCACHEPREFIX=/.cache/python/
# Install system packages
RUN apt update && apt install -y \
    # For git pip install
    git \
    # Python
    python3-pip \
    python-is-python3 \
    # Java to build our fork of Hydra
    default-jre \
    # For audio libraries
    ffmpeg \
    sox \
    libavdevice-dev \
    libffi8 \
    # Clean up
    && rm -rf /var/lib/apt/lists/*
# Feed `pyproject.toml` to the build context
ADD pyproject.toml /repo/pyproject.toml
# Install Python dependencies
RUN pip install --no-cache-dir --break-system-packages -e /repo[all] \
    && pip install --no-cache-dir --break-system-packages --no-build-isolation \
        git+https://github.com/state-spaces/mamba.git@e0761ece1db07e0949dd88b4f4cd440420a19fd9 \
        git+https://github.com/Dao-AILab/causal-conv1d.git@69e6dadc28b169a4c49cb86b586f64ee90242c70